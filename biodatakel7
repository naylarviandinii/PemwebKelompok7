<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tim Proyek - Tambah Jaya Market</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        :root {
            --primary: #2e4d3d; /* Hijau Tua */
            --accent: #4caf50;  /* Hijau Terang */
            --bg-light: #f4f9f4;
            --white: #ffffff;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }

        body { background-color: var(--bg-light); color: var(--primary); padding-bottom: 50px; }

        /* Navbar */
        .navbar {
            display: flex; justify-content: space-between; align-items: center;
            padding: 20px 8%; background: var(--white); box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }
        .logo { font-weight: 800; font-size: 1.4rem; }
        .logo span { color: var(--accent); }

        .header-team { text-align: center; padding: 60px 20px; }
        .header-team h1 { font-size: 2.5rem; color: var(--primary); }

        /* Container Team */
        .team-container {
            max-width: 1100px; margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px; padding: 0 20px;
        }

        /* Card Design */
        .team-card {
            background: var(--white); 
            border-radius: 25px; 
            padding: 40px 25px;
            text-align: center; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
            border-bottom: 5px solid transparent;
        }

        .team-card:hover {
            transform: translateY(-10px);
            border-bottom: 5px solid var(--accent);
        }

        .img-area {
            width: 130px; height: 130px; margin: 0 auto 20px;
            border-radius: 50%; border: 4px solid var(--accent); overflow: hidden;
        }
        .img-area img { width: 100%; height: 100%; object-fit: cover; }

        .npm-badge { 
            background: var(--bg-light); color: var(--accent);
            padding: 5px 15px; border-radius: 20px;
            font-size: 0.8rem; font-weight: bold; display: inline-block; margin-bottom: 20px;
        }

        .social-links { display: flex; justify-content: center; gap: 15px; margin-bottom: 25px; }
        .social-links a {
            color: var(--primary); font-size: 1.2rem; transition: 0.3s;
        }
        .social-links a:hover { color: var(--accent); transform: scale(1.2); }

        /* TOMBOL YANG ANDA CARI ADA DI SINI */
        .btn-more {
            display: block;
            background-color: var(--primary);
            color: white;
            text-decoration: none;
            padding: 12px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.9rem;
            transition: 0.3s;
            margin-top: 10px;
        }

        .btn-more:hover {
            background-color: var(--accent);
            box-shadow: 0 5px 15px rgba(76, 175, 80, 0.3);
        }

        footer { text-align: center; margin-top: 60px; color: #888; font-size: 0.8rem; }
    </style>
</head>
<body>

    <nav class="navbar">
        <div class="logo">TAMBAH JAYA<span>MARKET</span></div>
        <div style="font-weight: 600; color: #888;">OUR TEAM</div>
    </nav>

    <header class="header-team">
        <h1>Anggota Tim Kami</h1>
    </header>

    <div class="team-container">
        
        <div class="team-card">
            <div class="img-area">
                <img src="https://via.placeholder.com/150" alt="Foto">
            </div>
            <h3>Cutrin Joy M.T Sihombing</h3>
            <div class="npm-badge">NPM 24082010170</div>
            <div class="social-links">
                <a href="#"><i class="fab fa-instagram"></i></a>
                <a href="#"><i class="fab fa-linkedin"></i></a>
            </div>
            <a href="#" class="btn-more">Pelajari Selengkapnya</a>
        </div>

        <div class="team-card">
            <div class="img-area">
                <img src="https://via.placeholder.com/150" alt="Foto">
            </div>
            <h3>Nayla Arviandini</h3>
            <div class="npm-badge">NPM 24082010146</div>
            <div class="social-links">
                <a href="#"><i class="fab fa-instagram"></i></a>
                <a href="#"><i class="fab fa-github"></i></a>
            </div>
            <a href="#" class="btn-more">Pelajari Selengkapnya</a>
        </div>

        <div class="team-card">
            <div class="img-area">
                <img src="https://via.placeholder.com/150" alt="Foto">
            </div>
            <h3>Kharenina Rizqy P.N</h3>
            <div class="npm-badge">NPM 24082010144</div>
            <div class="social-links">
                <a href="#"><i class="fab fa-instagram"></i></a>
                <a href="#"><i class="fab fa-linkedin"></i></a>
            </div>
            <a href="#" class="btn-more">Pelajari Selengkapnya</a>
        </div>

    </div>

    <footer>
        &copy; 2026 Teams Project Website Programming - UPN "VETERAN" Jawa Timur 
    </footer>

</body>
</html>